{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Grimoire plugin catalog",
  "type": "object",
  "required": ["version", "plugins"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "updated": { "type": "string" },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "author", "description", "manifestUrl"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 60 },
          "author": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 10, "maxLength": 280 },
          "manifestUrl": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          },
          "homepage": { "type": "string", "format": "uri" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "permissions": {
            "type": "array",
            "items": {
              "enum": ["scene:read", "scene:write", "tool", "broadcast", "metadata", "dice"]
            }
          }
        }
      }
    }
  }
}
