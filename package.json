{
  "name": "grimoire",
  "version": "0.1.0",
  "description": "A virtual tabletop for Nextcloud",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite build --mode development --watch",
    "build": "vite build && node -e \"const fs=require('fs');fs.mkdirSync('css',{recursive:true});fs.copyFileSync('js/grimoire-style.css','css/grimoire-style.css')\"",
    "demo": "vite preview --port 5180 || npx serve ."
  },
  "dependencies": {
    "@nextcloud/axios": "^2.5.0",
    "@nextcloud/initial-state": "^2.2.0",
    "@nextcloud/router": "^3.0.1",
    "cannon-es": "^0.20.0",
    "konva": "^9.3.0",
    "three": "^0.160.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.2.0"
  }
}